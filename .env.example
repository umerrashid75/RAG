# PaperGraph-RAG environment variables — copy to .env and fill in values.
# NEVER commit .env to source control.

# --- Provider selection (free-tier defaults) ---
LLM_PROVIDER=groq            # groq | gemini | openai
EMBEDDING_PROVIDER=fastembed # fastembed (local, free) | openai

# --- API keys ---
# Only the active LLM provider's key is required. Get a free Groq key:
#   https://console.groq.com
GROQ_API_KEY=

# Optional provider upgrades (leave blank if unused)
OPENAI_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
# Optional: enables the CRAG web-search fallback
TAVILY_API_KEY=

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
# Required only for managed Qdrant Cloud
QDRANT_API_KEY=

# --- Graph DB (Neo4j) — optional; app degrades to vector RAG without it ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=papergraph_dev
# Set true to run LLM entity/relation extraction into Neo4j during ingestion.
ENABLE_GRAPH=false

# --- Optional overrides (defaults shown) ---
# QDRANT_COLLECTION=papergraph_chunks
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSIONS=384
# GENERATION_MODEL=llama-3.3-70b-versatile
# MAX_ITERATIONS=3
# CRAG_CONFIDENCE_THRESHOLD=0.7
